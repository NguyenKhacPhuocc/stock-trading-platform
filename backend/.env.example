# Backend (NestJS) — CHỈ biến dùng cho API.
#
# Quy ước: code cần env mới → sửa .env.example này trước, rồi đồng bộ backend/.env.
# Sao chép: copy .env.example .env   (cùng thư mục backend/)
# Chạy: cd backend && npm run start:dev  (Nest load .env từ cwd)

# --- PostgreSQL (TypeORM — xem database.module.ts) ---
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=123456
DB_DATABASE=stock_db
DB_SYNCHRONIZE=true
DATABASE_URL=postgresql://postgres:123456@localhost:5433/stock_db

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=5

# --- HTTP ---
BACKEND_PORT=3002
NODE_ENV=development
# CORS: nhiều origin cách nhau bằng dấu phẩy (tùy chọn)
# FRONTEND_URL=http://localhost:3000,http://localhost:3001

# --- Auth: access JWT + refresh opaque (hash trong DB) ---
JWT_SECRET=your_super_secret_key_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Fallback nếu không set JWT_ACCESS_EXPIRES_IN
JWT_EXPIRES_IN=7d
COOKIE_SECRET=your_cookie_secret_change_in_production

# --- Gọi AI service (AiModule) ---
AI_SERVICE_URL=http://localhost:8000

# --- SSI snapshot ingest (startup, theo ngày) ---
# Skip ingest khi đã có SUCCESS cho ngày hiện tại (true/false)
MARKET_INGEST_SKIP_IF_SUCCESS=true
SSI_SNAPSHOT_BASE_URL=https://iboard-query.ssi.com.vn/stock/exchange
SSI_SNAPSHOT_BOARD_ID=MAIN
SSI_SNAPSHOT_TIMEOUT_MS=15000
SSI_SNAPSHOT_ORIGIN=https://iboard.ssi.com.vn
SSI_SNAPSHOT_REFERER=https://iboard.ssi.com.vn/
SSI_SNAPSHOT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
